{
    "name": "pronnect/lib-gpwebpay",
    "version": "1.0.3",
    "description": "GP Webpay Gateway",
    "type": "library",
    "require": {
        "php": ">=8.0",
        "ext-dom": "*",
        "ext-soap": "*",
        "ext-openssl": "*",
        "psr/log": "*"
    },
    "authors": [
        {
            "name": "Pronnect s.r.o.",
            "email": "info@pronnect.sk"
        }
    ],
    "license": "MIT",
    "require-dev": {
        "phpunit/phpunit": "^9.4",
        "mockery/mockery": "^1.4",
        "monolog/monolog": "*",
        "phpunit/php-code-coverage": "^9.2"
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-clover coverage.xml"
    },
    "autoload": {
        "psr-4": {
            "Pronnect\\GpWebPay\\": "src/",
            "Pronnect\\GpWebPayApi\\": "api/",
            "Pronnect\\GpWebPayTest\\": "tests/"
        }
    }
}
