# Test certificate paths (relative to project root)
# Default values match the certs/ directory structure — override if needed
GPWEBPAY_PRIVATE_KEY=certs/gpwebpay-pvk_GPE_TEST.key
GPWEBPAY_PUBLIC_KEY=certs/gpwebpay-pub_GPE_TEST.pem
GPWEBPAY_MERCHANT_PRIVATE_KEY=certs/gpwebpay-pvk_MERCHANT_TEST.key

# Password for the merchant private key
GPWEBPAY_MERCHANT_PRIVATE_KEY_PASSWORD=your_test_key_password

# GitHub Actions secrets (set in repo Settings → Secrets → Actions):
#   CERT_GPE_PRIVATE_B64        base64-encoded content of gpwebpay-pvk_GPE_TEST.key
#   CERT_GPE_PUBLIC_B64         base64-encoded content of gpwebpay-pub_GPE_TEST.pem
#   CERT_MERCHANT_PRIVATE_B64   base64-encoded content of gpwebpay-pvk_MERCHANT_TEST.key
#   GPWEBPAY_MERCHANT_PRIVATE_KEY_PASSWORD  plain text password
#   CODECOV_TOKEN               token from codecov.io
#
# To generate base64 values locally:
#   base64 -i certs/gpwebpay-pvk_GPE_TEST.key | tr -d '\n'
